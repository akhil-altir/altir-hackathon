# Copy this file to .env for local overrides (gitignored).
# Environment-specific defaults live in:
#   .env.development  — loaded by `next dev`              (SQLite)
#   .env.staging      — loaded manually / Railway staging (PostgreSQL)
#   .env.production   — loaded by Railway production      (PostgreSQL)

# ── Database ────────────────────────────────────────────────────────────────
# The predev/prebuild script reads DATABASE_PROVIDER and automatically
# rewrites prisma/schema.prisma before every `next dev` and `next build`.

# Development (SQLite — no setup needed):
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Staging / Production (PostgreSQL on Railway):
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/altir_tech_day?schema=public"
